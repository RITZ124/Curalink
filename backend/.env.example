PORT=5000
MONGODB_URI=mongodb://localhost:27017/curalink
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── LLM OPTION A: Ollama (local, recommended) ──────────────────────
# Install: https://ollama.com | Then: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── LLM OPTION B: HuggingFace (free tier) ─────────────────────────
# Get token: https://huggingface.co/settings/tokens
# HF_API_TOKEN=hf_your_token_here
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── LLM OPTION C: Anthropic (paid, demo backup) ───────────────────
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── PubMed (NCBI rate-limit compliance) ──────────────────────────
PUBMED_EMAIL=research@curalink.ai

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
